# Copy this file to .env and fill values.
# Existing keys like PLACES_API_KEY can stay as they are.

# Local development example:
DATABASE_URL=postgresql://aramabul:CHANGE_ME@127.0.0.1:5432/aramabul
DB_SSL=false
API_HOST=127.0.0.1
API_PORT=8787
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Optional alternative source for fuel station data:
# YANDEX_MAPS_API_KEY=...
