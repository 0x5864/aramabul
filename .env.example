# Copy this file to .env and fill values.
# Existing keys like PLACES_API_KEY can stay as they are.

# Local development example:
DATABASE_URL=postgresql://aramabul:CHANGE_ME@127.0.0.1:5432/aramabul
DB_SSL=false
API_HOST=127.0.0.1
API_PORT=8787
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Optional: email verification setup
APP_ORIGIN=http://127.0.0.1:8787
EMAIL_FROM=no-reply@example.com
# Use either EMAIL_SMTP_URL or host/port credentials below.
# EMAIL_SMTP_URL=smtps://user:pass@smtp.example.com:465
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=example-user
EMAIL_SMTP_PASS=example-pass

# Optional alternative source for fuel station data:
# YANDEX_MAPS_API_KEY=...
