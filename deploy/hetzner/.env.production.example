# Copy to .env on the server and fill real values.
# Keep this file out of git after you make the real .env.

DATABASE_URL=postgresql://aramabul:CHANGE_ME@127.0.0.1:5432/aramabul
DB_SSL=false
API_HOST=127.0.0.1
API_PORT=8787
NODE_ENV=production
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Keep any existing API keys you already use:
# PLACES_API_KEY=...
# YANDEX_MAPS_API_KEY=...

# Email verification
APP_ORIGIN=https://example.com
EMAIL_FROM=no-reply@example.com
# Use either EMAIL_SMTP_URL or host/port credentials below.
# EMAIL_SMTP_URL=smtps://user:pass@smtp.example.com:465
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=example-user
EMAIL_SMTP_PASS=example-pass
