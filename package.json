{
  "name": "neredeyenir",
  "version": "1.0.0",
  "private": true,
  "description": "NeredeYenir frontend + PostgreSQL API",
  "scripts": {
    "start": "node backend/server.js",
    "api": "node backend/server.js",
    "db:migrate": "node backend/scripts/migrate.js",
    "db:import:venues": "node backend/scripts/import-venues.js",
    "db:setup": "npm run db:migrate && npm run db:import:venues",
    "db:setup:prod": "npm run db:migrate",
    "fetch:pastaneler": "node scripts/fetch-google-pastaneler.js",
    "fetch:akaryakit": "node scripts/fetch-google-akaryakit.js",
    "fetch:akaryakit:yandex": "node scripts/fetch-yandex-akaryakit.js",
    "fetch:eczane:nbtecz": "node scripts/fetch-nbtecz-eczane.js",
    "fetch:nobetci:eczane:nbtecz": "node scripts/fetch-nbtecz-nobetci.js",
    "update:eczane:daily": "npm run fetch:eczane:nbtecz && npm run fetch:nobetci:eczane:nbtecz",
    "build:veteriner:google": "node scripts/fetch-google-veteriner.js",
    "build:veteriner:single": "node scripts/fetch-google-veteriner.js",
    "build:veteriner:all-single": "node scripts/run-veteriner-districts-single.js",
    "build:kuafor:data": "node scripts/build-category-data.js --category kuafor",
    "build:eczane:data": "node scripts/build-category-data.js --category eczane",
    "build:nobetci:eczane:data": "node scripts/fetch-nbtecz-nobetci.js",
    "build:veteriner:data": "node scripts/build-category-data.js --category veteriner",
    "build:akaryakit:data": "node scripts/build-category-data.js --category akaryakit",
    "build:eczane:data": "node scripts/build-category-data.js --category eczane",
    "build:atm:data": "node scripts/build-category-data.js --category atm",
    "build:kargo:data": "node scripts/build-category-data.js --category kargo",
    "build:noter:data": "node scripts/build-category-data.js --category noter",
    "build:asm:data": "node scripts/build-category-data.js --category asm",
    "build:dis-klinikleri:data": "node scripts/build-category-data.js --category dis-klinikleri",
    "build:duraklar:data": "node scripts/build-category-data.js --category duraklar",
    "build:otopark:data": "node scripts/build-category-data.js --category otopark"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.16.3"
  }
}
